[
  {
    "trigger": {
      "owner": "Raqibreyaz",
      "context": "deploy/backend",
      "repo": "Raqibreyaz/Storra",
      "events": ["push", "pull_request"],
      "branch": "main"
    },
    "workflow": {
      "workDir": "Backend/",
      "install": "pnpm install --frozen-lockfile",
      "reload": "pm2 startOrReload ecosystem.config.js",
      "packageManifest": ["package.json", "pnpm-lock.yaml"]
    },
    "target": {
      "type": "ssh",
      "host": "storra-backend.servehttp.com",
      "healthUrl": "127.0.0.1:8080/health",
      "username": "ubuntu",
      "projectPath": "/home/ubuntu/Storra",
      "auth": {
        "sshKey": "AWS_SSH_KEY"
      }
    }
  },
  {
    "trigger": {
      "owner": "Raqibreyaz",
      "context": "deploy/backend",
      "repo": "Raqibreyaz/Storra",
      "events": ["push", "pull_request"],
      "branch": "main"
    },
    "workflow": {
      "workDir": "Backend/",
      "install": "pnpm install --frozen-lockfile",
      "reload": "pm2 startOrReload ecosystem.config.js",
      "packageManifest": ["package.json", "pnpm-lock.yaml"]
    },
    "target": {
      "type": "local",
      "healthUrl": "127.0.0.1:8080/health",
      "projectPath": "/home/ubuntu/Storra"
    }
  },
  {
    "trigger": {
      "context": "deploy/frontend",
      "repo": "Raqibreyaz/Storra",
      "events": ["push", "pull_request"],
      "branch": "main"
    },
    "workflow": {
      "workDir": "Frontend/",
      "install": "pnpm install --frozen-lockfile",
      "build": "pnpm build",
      "mode": "build" //'build' or 'static'
    },
    "target": {
      "type": "s3",
      "publishDir": "dist/",
      "auth": {
        "accessKeyId": "AWS_ACCESS_KEY_ID",
        "secretAccessKey": "AWS_SECRET_ACCESS_KEY",
        "region": "AWS_REGION",
        "s3BucketName": "AWS_S3_BUCKET",
        "cloudfrontId": "CLOUDFRONT_DISTRIBUTION_ID"
      }
    }
  }
]
